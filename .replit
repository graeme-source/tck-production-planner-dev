modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
SHOPIFY_CLIENT_ID = "e355d017992f9dbfa132ee7d06e61ec6"
SHOPIFY_STORE_DOMAIN = "the-calzone-kitchen.myshopify.com"
APC_ACCOUNT_NUMBER = "TCK001"
APC_API_BASE = "https://apc.hypaship.com/api/3.0"
