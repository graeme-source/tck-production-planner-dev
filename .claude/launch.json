{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-lc", "PATH=/opt/homebrew/bin:$PATH pnpm run dev"],
      "cwd": "artifacts/api-server",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "frontend",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-lc", "PATH=/opt/homebrew/bin:$PATH pnpm exec vite --config vite.config.ts --host 0.0.0.0 --port 5273 --strictPort"],
      "cwd": "artifacts/production-planner",
      "port": 5273,
      "autoPort": true
    }
  ]
}
